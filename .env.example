# /agentd — environment template
#
# Copy this file to `.env` and fill in the values you need. Everything is
# optional; the daemon will boot without any of these set, but you won't be
# able to run agents until at least one of the auth values is configured.

# ── Networking ────────────────────────────────────────────────────────────
# Host port the daemon should be reachable on.
AGENTD_PORT=3773

# Host directory containing the git repos you want agents to operate on.
# Tasks reference repos by their in-container path, e.g. /repos/myproject.
REPOS_DIR=./repos

# ── Agent CLI auth ────────────────────────────────────────────────────────
# Either populate these here OR mount the host CLI configs into the
# container — see docs/docker.md.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Auto-PR ───────────────────────────────────────────────────────────────
# Personal access token used by `gh pr create` when --pr is set on a task or
# template. Must include the `repo` scope. Generate at
# https://github.com/settings/tokens.
GH_TOKEN=
