{
  "name": "agentd",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun apps/daemon/src/index.ts",
    "serve": "bun apps/daemon/src/index.ts --host 0.0.0.0",
    "build": "bun --filter @agentd/web build",
    "daemon": "bun --filter @agentd/daemon dev",
    "cli": "bun --filter @agentd/cli start",
    "dev": "bun --filter @agentd/web dev",
    "web:build": "bun --filter @agentd/web build",
    "desktop": "bun --filter @agentd/desktop start",
    "desktop:dev": "bun --filter @agentd/desktop dev",
    "desktop:build": "bun --filter @agentd/desktop build",
    "typecheck": "bun --filter '*' typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/bun": "^1.1.14"
  }
}
