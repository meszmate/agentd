{
  "name": "@meszmate/agentd",
  "version": "0.0.2",
  "description": "Remote coding-agent orchestrator. One process serves the daemon, web UI, WebSocket bus, and CLI for driving claude-code / codex agents across devices.",
  "license": "MIT",
  "author": "meszmate <meszmatew@gmail.com>",
  "homepage": "https://github.com/meszmate/agentd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meszmate/agentd.git"
  },
  "bugs": {
    "url": "https://github.com/meszmate/agentd/issues"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai-agent",
    "coding-agent",
    "daemon",
    "orchestrator",
    "tailscale",
    "remote-development"
  ],
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "bin": {
    "agentd": "./apps/cli/src/index.ts"
  },
  "files": [
    "apps/cli/src",
    "apps/cli/package.json",
    "apps/cli/tsconfig.json",
    "apps/daemon/src",
    "apps/daemon/package.json",
    "apps/daemon/tsconfig.json",
    "apps/telegram/src",
    "apps/telegram/package.json",
    "apps/telegram/tsconfig.json",
    "apps/discord/src",
    "apps/discord/package.json",
    "apps/discord/tsconfig.json",
    "apps/web/dist",
    "packages",
    "tsconfig.base.json",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "bun apps/daemon/src/index.ts",
    "serve": "bun apps/daemon/src/index.ts --host 0.0.0.0",
    "build": "bun --filter @agentd/web build",
    "daemon": "bun --filter @agentd/daemon dev",
    "cli": "bun --filter @agentd/cli start",
    "dev": "bun --filter @agentd/web dev",
    "web:build": "bun --filter @agentd/web build",
    "desktop": "bun --filter @agentd/desktop start",
    "desktop:dev": "bun --filter @agentd/desktop dev",
    "desktop:build": "bun --filter @agentd/desktop build",
    "typecheck": "bun --filter '*' typecheck",
    "prepublishOnly": "bun --filter @agentd/web build"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "discord.js": "^14.16.3",
    "drizzle-orm": "^0.36.4",
    "grammy": "^1.32.0",
    "hono": "^4.6.13",
    "node-pty": "^1.0.0",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/bun": "^1.1.14"
  }
}
